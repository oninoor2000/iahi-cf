# ============================================================
# IAHI Web Profile — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# ============================================================

# ---- Better Auth ----
BETTER_AUTH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BETTER_AUTH_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_BETTER_AUTH_URL=http://localhost:3000 # Base URL of your app

# ---- Cloudflare D1 ----
# Run: wrangler d1 create iahi-db
# Then copy the database_id here AND into wrangler.jsonc
CLOUDFLARE_D1_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ---- Cloudflare Account (for drizzle-kit migrations via REST API) ----
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_D1_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Email (SMTP via nodemailer, e.g. Gmail) ----
# Optional overrides (defaults match wrangler vars: smtp.gmail.com:587)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Gmail address to send from (must match the SMTP account)
SMTP_USER=yourname@gmail.com
# App password (NOT your account password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_PASS=xxxx xxxx xxxx xxxx
# "From" display name in emails
SMTP_FROM_NAME=IAHI - Perhimpunan Informatika Kesehatan Indonesia
# For production, set SMTP_USER and SMTP_PASS with: wrangler secret put SMTP_USER / SMTP_PASS
# Optional: wrangler secret put SMTP_HOST / SMTP_PORT if not using vars in wrangler.jsonc

# ---- App ----
VITE_APP_URL=https://iahi.flaener.workers.dev
